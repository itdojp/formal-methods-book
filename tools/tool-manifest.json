{
  "schemaVersion": 1,
  "policy": {
    "canonicalJapaneseSources": "book-config.ja.json reader pages; src/ja/appendices/appendices_draft.md is excluded",
    "artifact": {
      "retentionDays": 14,
      "maxOutputBytes": 16777216,
      "maxBytesPerExample": 67108864
    },
    "execution": {
      "timeout": "runner-enforced",
      "stdoutStderr": "runner-enforced",
      "retainedToolOutput": "post-run-retention-cap",
      "memory": "declared-budget-only"
    },
    "updates": {
      "cadence": "monthly",
      "automation": "Release assets are not Dependabot/Renovate package references; update by a dedicated audited PR.",
      "procedure": [
        "Confirm the official release/tag and immutable commit where available.",
        "Record the official asset URL and SHA-256 digest.",
        "Run manifest validation and the affected executable lane from a clean cache.",
        "Review command/schema/output changes and merge the version-only PR after CI."
      ]
    }
  },
